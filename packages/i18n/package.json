{
  "name": "@workspace/i18n",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "react": "^19",
    "react-dom": "^19",
    "@types/react": "^19",
    "@types/react-dom": "^19"
  },
  "exports": {
    ".": {
      "types": "./src/provider.tsx",
      "default": "./src/provider.tsx"
    },
    "./provider": {
      "types": "./src/provider.tsx",
      "default": "./src/provider.tsx"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    }
  },
  "files": [
    "src"
